      <script>
      // 胶囊滑块 Tabbar 交互逻辑
      function initCapsuleSliders() {
        // 桌面端胶囊滑块
        const capsuleTabs = document.querySelectorAll('.capsule-tab');
        const capsulePill = document.getElementById('capsulePill');
        
        // 移动端胶囊滑块
        const mobileCapsuleTabs = document.querySelectorAll('.mobile-capsule-tab');
        const mobileCapsulePill = document.getElementById('mobileCapsulePill');
        
        // 初始化桌面端滑块
        if (capsulePill && capsuleTabs.length > 0) {
          initCapsuleSlider(capsuleTabs, capsulePill);
        }
        
        // 初始化移动端滑块
        if (mobileCapsulePill && mobileCapsuleTabs.length > 0) {
          initCapsuleSlider(mobileCapsuleTabs, mobileCapsulePill);
        }
      }
      
      function initCapsuleSlider(tabs, pill) {
        // 不需要活跃页面逻辑，默认选择第一个标签页用于滑块定位
        let currentTab = tabs[0];
        
        function movePill(tab, animate = true) {
          if (!animate) {
            pill.style.transition = 'none';
          }
          pill.style.left = tab.offsetLeft + 'px';
          pill.style.width = tab.offsetWidth + 'px';
          if (!animate) {
            pill.offsetWidth;
            pill.style.transition = '';
          }
        }
        
        function switchTo(tab) {
          // 不需要切换活跃状态，只移动滑块位置
          movePill(tab);
        }
        
        tabs.forEach(tab => {
          // 移除之前的事件监听器，避免重复绑定
          tab.removeEventListener('click', handleTabClick);
          tab.removeEventListener('mouseenter', handleMouseEnter);
          tab.removeEventListener('mouseleave', handleMouseLeave);
          
          // 添加新的点击事件
          tab.addEventListener('click', handleTabClick);
          
          // 添加鼠标悬停事件 - 滑块跟随
          tab.addEventListener('mouseenter', handleMouseEnter);
          tab.addEventListener('mouseleave', handleMouseLeave);
          
          function handleTabClick(e) {
            // 添加点击动画效果
            this.style.transform = 'scale(0.95)';
            setTimeout(() => {
              this.style.transform = '';
            }, 150);
            
            // 允许链接正常跳转，不阻止默认行为
          }
          
          function handleMouseEnter() {
            // 鼠标悬停时，先显示滑块，然后移动到当前按钮
            pill.style.opacity = '1';
            movePill(this, true);
          }
          
          function handleMouseLeave() {
            // 鼠标离开时，滑块直接消失（不回到页面位置）
            pill.style.opacity = '0';
          }
        });
        
        // 监听窗口大小变化
        const tabbarContainer = tabs[0].closest('.capsule-tabbar, .mobile-capsule-tabbar');
        if (tabbarContainer) {
          new ResizeObserver(() => movePill(currentTab, false)).observe(tabbarContainer);
        }
        
        // 为搜索按钮添加滑块跟随效果
        const searchBtn = tabbarContainer ? tabbarContainer.querySelector('.capsule-search-btn') : null;
        if (searchBtn) {
          searchBtn.addEventListener('mouseenter', function() {
            pill.style.opacity = '1';
            movePill(this, true);
          });
          searchBtn.addEventListener('mouseleave', function() {
            pill.style.opacity = '0';
          });
        }
        
        // 初始化滑块位置
        movePill(currentTab);
      }
      
      // 页面加载完成后立即初始化滑块
      document.addEventListener('DOMContentLoaded', function() {
        initCapsuleSliders();
      });
      
      // 页面切换后重新初始化滑块（适用于单页应用或部分页面刷新）
      window.addEventListener('load', function() {
        setTimeout(initCapsuleSliders, 100); // 延迟确保DOM完全加载
      });
      
      // 监听URL变化（适用于单页应用）
      window.addEventListener('popstate', function() {
        setTimeout(initCapsuleSliders, 50);
      });
      
      // 监听页面可见性变化（适用于标签页切换）
      document.addEventListener('visibilitychange', function() {
        if (!document.hidden) {
          setTimeout(initCapsuleSliders, 100);
        }
      });
      
      // 移动端菜单切换函数
      function toggleMobileMenu() {
        const trigger = document.getElementById('mobileNavTrigger');
        const dropdown = document.getElementById('mobileDropdownMenu');
        
        if (!trigger || !dropdown) return;
        
        const isOpen = dropdown.classList.contains('open');
        
        if (isOpen) {
          dropdown.classList.remove('open');
          trigger.classList.remove('active');
        } else {
          dropdown.classList.add('open');
          trigger.classList.add('active');
        }
      }
      
      // 点击页面其他地方关闭菜单
      document.addEventListener('click', function(e) {
        const nav = document.querySelector('.mobile-bottom-nav');
        const dropdown = document.getElementById('mobileDropdownMenu');
        const trigger = document.getElementById('mobileNavTrigger');
        
        if (nav && dropdown && trigger && !nav.contains(e.target)) {
          dropdown.classList.remove('open');
          trigger.classList.remove('active');
        }
      });
      </script>